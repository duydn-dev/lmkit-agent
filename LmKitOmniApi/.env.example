# Database Connections
ConnectionStrings__Redis=localhost:6379
PostgreSql=Host=localhost;Database=lmkit;Username=postgres;Password=password

# Vector Store
VectorStore__BaseUrl=http://localhost:6334
VectorStore__CollectionName=lmkit_chunks

# JWT Secret
JwtSettings__SecretKey=your_very_secure_jwt_secret_key_change_me_in_production

# LiveKit WebRTC Voice
LiveKit__Url=ws://localhost:7880
LiveKit__ApiKey=your_livekit_api_key
LiveKit__ApiSecret=your_livekit_api_secret

# Telegram (Optional)
TelegramSettings__BotToken=YOUR_BOT_TOKEN_HERE
TelegramSettings__ChatId=YOUR_CHAT_ID_HERE

# MCP Servers (Optional)
Mcp__Servers__0__Name=ExampleMcpServer
Mcp__Servers__0__BaseUrl=http://localhost:5005
Mcp__Servers__0__ApiKey=optional-api-key
